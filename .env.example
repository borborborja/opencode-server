# --- Server opencode ---
OPENCODE_SERVER_PASSWORD=changeme
OPENROUTER_API_KEY=
GIT_USER_NAME=opencode
GIT_USER_EMAIL=agent@opencode.local
AUTO_UPDATE=true

# --- MCP ---
# Token del contenedor n8n-mcp (para el MCP remoto "n8n"). Copia el AUTH_TOKEN de n8n-mcp.
N8N_MCP_AUTH_TOKEN=

# --- Plugins opcionales de opencode (lista separada por comas) ---
# p.ej. OPENCODE_PLUGINS=opencode-telegram-notification
OPENCODE_PLUGINS=

# --- Bot de Telegram (servicio opencode-telegram) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
OPENCODE_MODEL_PROVIDER=openrouter
OPENCODE_MODEL_ID=anthropic/claude-sonnet-4.5
